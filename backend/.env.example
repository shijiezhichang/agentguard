# AgentGuard 环境变量配置模板
# 复制为 .env 并填入实际值

# Railway PostgreSQL 连接字符串（部署后从 Railway 获取）
# 格式: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:port/database

# Gmail SMTP 配置
GMAIL_SMTP_USER=ls530224750@gmail.com
GMAIL_SMTP_PASSWORD=your_gmail_app_password

# CORS 允许的域名（逗号分隔）
CORS_ORIGINS=https://globalxyz.xyz,https://www.globalxyz.xyz

# 扫描缓存时间（秒），默认 86400（24 小时）
SCAN_CACHE_TTL=86400

# 服务端口
PORT=8000
